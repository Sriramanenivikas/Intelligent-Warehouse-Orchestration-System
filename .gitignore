# ========================================
# IWOS - Git Ignore File
# ========================================

# Logs
logs/
*.log
nohup.out

# Backend - Java/Maven
backend/*/target/
backend/*/.mvn/
backend/*/mvnw
backend/*/mvnw.cmd
*.class
*.jar
*.war
*.ear
*.iml
.idea/
.vscode/
.settings/
.project
.classpath

# Frontend - React/Node
frontend/*/node_modules/
frontend/*/build/
frontend/*/dist/
frontend/*/.env.local
frontend/*/.env.development.local
frontend/*/.env.test.local
frontend/*/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store

# Database
*.db
*.sqlite
*.sqlite3

# Docker
docker-compose.override.yml

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.tmp

# Environment
.env
*.pid

# Test coverage
coverage/
*.coverage

# Temporary files
temp/
tmp/

# Build artifacts
build/
dist/
out/
