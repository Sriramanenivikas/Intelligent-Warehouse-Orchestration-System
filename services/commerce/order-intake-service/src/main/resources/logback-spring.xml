<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty name="springAppName" source="spring.application.name" defaultValue="order-intake-service"/>
    <springProperty name="springProfile" source="spring.profiles.active" defaultValue="local"/>
    <property name="LOG_FILE" value="${ORDER_INTAKE_LOG_FILE:-logs/order-intake-service.log}"/>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${springAppName}","env":"${springProfile}"}</customFields>
            <includeMdc>true</includeMdc>
            <mdcKeyFieldName>traceId=trace_id</mdcKeyFieldName>
            <mdcKeyFieldName>spanId=span_id</mdcKeyFieldName>
            <mdcKeyFieldName>request_id=request_id</mdcKeyFieldName>
        </encoder>
    </appender>

    <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/order-intake-service.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${springAppName}","env":"${springProfile}"}</customFields>
            <includeMdc>true</includeMdc>
            <mdcKeyFieldName>traceId=trace_id</mdcKeyFieldName>
            <mdcKeyFieldName>spanId=span_id</mdcKeyFieldName>
            <mdcKeyFieldName>request_id=request_id</mdcKeyFieldName>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE_JSON"/>
        <appender-ref ref="FILE_JSON"/>
    </root>
</configuration>
