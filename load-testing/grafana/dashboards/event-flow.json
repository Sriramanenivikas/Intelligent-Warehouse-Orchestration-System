{
  "dashboard": {
    "title": "IWOS - Event Flow & Kafka Metrics",
    "tags": ["iwos", "kafka", "events", "cqrs"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Event Flow Rate by Topic",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "rate(kafka_server_brokertopicmetrics_messagesin_total{topic=\"order.events\"}[5m])",
            "legendFormat": "order.events",
            "refId": "A"
          },
          {
            "expr": "rate(kafka_server_brokertopicmetrics_messagesin_total{topic=\"inventory.events\"}[5m])",
            "legendFormat": "inventory.events",
            "refId": "B"
          },
          {
            "expr": "rate(kafka_server_brokertopicmetrics_messagesin_total{topic=\"warehouse.events\"}[5m])",
            "legendFormat": "warehouse.events",
            "refId": "C"
          },
          {
            "expr": "rate(kafka_server_brokertopicmetrics_messagesin_total{topic=\"payment.events\"}[5m])",
            "legendFormat": "payment.events",
            "refId": "D"
          },
          {
            "expr": "rate(kafka_server_brokertopicmetrics_messagesin_total{topic=\"notification.events\"}[5m])",
            "legendFormat": "notification.events",
            "refId": "E"
          }
        ],
        "yaxes": [
          {
            "label": "Events/sec",
            "format": "short"
          }
        ]
      },
      {
        "id": 2,
        "title": "Kafka Consumer Lag",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "kafka_consumergroup_lag",
            "legendFormat": "{{consumergroup}} - {{topic}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "Lag (messages)",
            "format": "short"
          }
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [10000],
                "type": "gt"
              },
              "query": {
                "params": ["A", "5m", "now"]
              },
              "reducer": {
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "message": "Kafka consumer lag is too high!",
          "name": "High Consumer Lag Alert"
        }
      },
      {
        "id": 3,
        "title": "Event Store - Events Written",
        "type": "stat",
        "gridPos": {"x": 12, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(event_store_events_total)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Event Processing Latency",
        "type": "graph",
        "gridPos": {"x": 18, "y": 8, "w": 6, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(event_processing_duration_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(event_processing_duration_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Latency (ms)",
            "format": "ms"
          }
        ]
      },
      {
        "id": 5,
        "title": "CQRS - Write vs Read Operations",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(pg_stat_database_xact_commit{datname=\"iwos\"}[5m])",
            "legendFormat": "Writes (PostgreSQL)",
            "refId": "A"
          },
          {
            "expr": "rate(mongodb_op_counters_total{type=\"query\"}[5m])",
            "legendFormat": "Reads (MongoDB)",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Operations/sec",
            "format": "ops"
          }
        ]
      },
      {
        "id": 6,
        "title": "Event Replay Status",
        "type": "table",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "event_replay_progress",
            "format": "table",
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {},
              "renameByName": {
                "aggregate_id": "Order ID",
                "events_replayed": "Events Replayed",
                "target_version": "Target Version"
              }
            }
          }
        ]
      },
      {
        "id": 7,
        "title": "Kafka Broker Health",
        "type": "stat",
        "gridPos": {"x": 0, "y": 24, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "kafka_server_replicamanager_underreplicatedpartitions",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "text": {
            "titleSize": 20
          }
        }
      },
      {
        "id": 8,
        "title": "Saga Execution Status",
        "type": "piechart",
        "gridPos": {"x": 8, "y": 24, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "sum by (status) (saga_execution_total)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Compensating Transactions",
        "type": "stat",
        "gridPos": {"x": 16, "y": 24, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "sum(saga_compensation_total)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        }
      }
    ],
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "version": 1
  }
}
