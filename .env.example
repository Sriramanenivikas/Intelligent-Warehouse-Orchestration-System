AWS_SECRET_ACCESS_KEY=

# DynamoDB
DYNAMODB_ENDPOINT=http://localhost:8000

# Temporal
TEMPORAL_ADDRESS=localhost:7233

# Payment Gateways
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# JWT
JWT_SECRET=your-256-bit-secret-key-here
